<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="HelperBubbleStyle" TargetType="Border">
        <Setter Property="Width" Value="166" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Background" Value="{StaticResource HelperBubbleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HelperBubbleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8"
                                  Opacity="0.12"
                                  ShadowDepth="2" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HelperCircleButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="76" />
        <Setter Property="Height" Value="76" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource HelperCircleBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HelperCircleBorderBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="38">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16"
                                              Opacity="0.25"
                                              ShadowDepth="4" />
                        </Border.Effect>
                        <Image Source="{Binding AvatarImage}"
                               Stretch="UniformToFill" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
