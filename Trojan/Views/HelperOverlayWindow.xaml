<Window x:Class="Trojan.Views.HelperOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
		xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"  
        
		Title="HelperOverlayWindow"
        Width="850"
		Height="620"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        Focusable="True"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="Transparent">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="560"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>


        <Image Grid.Column="1"
       Width="80"
       Height="80"
       Margin="0,0,8,22"
       HorizontalAlignment="Right"
       VerticalAlignment="Bottom"
       Stretch="Uniform"
       Panel.ZIndex="999"
       IsHitTestVisible="False"
       gif:ImageBehavior.AnimatedSource="{Binding AvatarGif}"/>

        <!-- NOTE -->
        <Border x:Name="NotePanel"
        Grid.Column="0"
        Width="500"
        Height="560"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="24"
        Margin="20"
        VerticalAlignment="Center"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
        Visibility="{Binding IsNoteVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.18"/>
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.92"
                        ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Style>
                <Style TargetType="Border">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsNoteVisible}" Value="True">

                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="0.92"
                                                 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="0.92"
                                                 Duration="0:0:0.2"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>

                        </DataTrigger>

                    </Style.Triggers>

                </Style>
            </Border.Style>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- HANDLE -->
                <Border Width="42"
							Height="6"
							CornerRadius="3"
							Background="#8F8791"
							HorizontalAlignment="Center"
							Margin="0,0,0,20"/>

                <!-- TITLE -->
                <Border Grid.Row="1"
							Background="#EAE4EC"
							CornerRadius="10"
							Padding="16">

                    <StackPanel>

                        <TextBlock Text="Naslov"
									   FontSize="14"
									   Foreground="#5C5661"/>

                        <TextBox Text="{Binding Main.SelectedNote.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
									 FontSize="22"
									 Background="Transparent"
									 BorderThickness="0"/>
                    </StackPanel>

                </Border>

                <!-- TOOLBAR -->
                <Grid Grid.Row="2"
						  Margin="8,12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">

                        <Button Content="B"
									FontWeight="Bold"
									Width="32"
									Height="32"
									Background="Transparent"
									BorderThickness="0"
									Click="BoldButton_Click"/>

                        <Button Content="☰"
									Width="32"
									Height="32"
									Background="Transparent"
									BorderThickness="0"
									Click="BulletListButton_Click"/>
                    </StackPanel>

                </Grid>

                <!-- DESCRIPTION -->
                <Border Grid.Row="3"
							Background="#EAE4EC"
							CornerRadius="10"
							Padding="16">

                    <StackPanel>

                        <TextBlock Text="Opis"
									   FontSize="14"
									   Foreground="#5C5661"/>

                        <RichTextBox x:Name="NoteContentRichTextBox"
										 VerticalScrollBarVisibility="Auto"
										 Background="Transparent"
										 BorderThickness="0"
										 FontSize="22"
										 TextChanged="NoteContentRichTextBox_TextChanged"/>
                    </StackPanel>

                </Border>

                <Button Grid.Row="4"
							Content="Shrani beležko"
							Margin="0,16,0,0"
							FontSize="20"
							FontWeight="SemiBold"
							Background="#DCCFEB"
							Foreground="#4A4150"
							BorderThickness="0"
							Height="56"
							Command="{Binding SaveNoteCommand}"
							Cursor="Hand"/>


                <Button Grid.Row="5"
						Content="Ogled starih beležk"
						Margin="0,16,0,0"
						FontSize="20"
						FontWeight="SemiBold"
						Background="#DCCFEB"
						Foreground="#4A4150"
						BorderThickness="0"
						Height="56"
						Command="{Binding OpenHistoryCommand}"
						Cursor="Hand"/>

            </Grid>





        </Border>

        <Border Grid.Column="0"
        Width="500"
        Height="560"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="20"
        Margin="20"
        VerticalAlignment="Center"
        Visibility="{Binding IsHistoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HANDLE -->
                <Border Width="42"
							Height="6"
							CornerRadius="3"
							Background="#8F8791"
							HorizontalAlignment="Center"
							Margin="0,0,0,24"/>

                <TextBlock Grid.Row="0"
							   Margin="0,0,0,12"
							   HorizontalAlignment="Center"
							   FontSize="22"
							   FontWeight="SemiBold"
							   Foreground="#4A4150"
							   Text="Vse beležke"/>

                <ListBox Grid.Row="1"
							 Margin="0,0,0,12"
							 Background="#FBF7FB"
							 BorderThickness="0"
							 HorizontalContentAlignment="Stretch"
							 ItemsSource="{Binding Main.Notes}"
							 SelectedItem="{Binding Main.SelectedNote, Mode=TwoWay}"
							 MouseDoubleClick="NotesHistoryListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
										Margin="0,0,0,10"
										CornerRadius="10"
										BorderThickness="1"
										BorderBrush="#E3DAE8"
										Background="#FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title, TargetNullValue=(brez naslova)}"
													   FontSize="17"
													   FontWeight="SemiBold"
													   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=Kreirano: {0:dd.MM.yyyy HH:mm}}"
													   Margin="0,4,0,0"
													   FontSize="12"
													   Foreground="#5C5661"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
												Content="Odpri"
												Padding="12,6"
												Margin="10,0,0,0"
												Command="{Binding DataContext.OpenNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ADD BUTTON -->
                <StackPanel Grid.Row="2">
                    <Button Content="Dodaj beležko"
							Height="56"
							Margin="0,0,0,8"
							Background="#DCCFEB"
							BorderThickness="0"
							FontSize="20"
							FontWeight="SemiBold"
							Command="{Binding CreateNoteCommand}"/>
                    <Button Content="Izbriši izbrano"
								Height="44"
								Background="#E8DDE8"
								BorderThickness="0"
								FontSize="16"
								Command="{Binding DeleteNoteCommand}"/>
                </StackPanel>
            </Grid>


        </Border>


        <Border Grid.Column="0"
				Width="320"
				Height="300"
				Background="#F7F2F8"
				CornerRadius="18"
				Padding="24"
				Margin="20"
				VerticalAlignment="Center"
				Opacity="0"
				RenderTransformOrigin="0.5,0.5"
				Visibility="{Binding IsJokeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.9"
									ScaleY="0.9"/>
            </Border.RenderTransform>

            <StackPanel>

                <TextBlock Text="Šale"
							   FontSize="36"
							   FontWeight="SemiBold"
							   Margin="0,0,0,20"/>

                <TextBlock Text="{Binding JokeText}"
							   TextWrapping="Wrap"
							   FontSize="18"
							   Foreground="#514B56"
							   LineHeight="28"
							   Margin="0,0,0,28"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
								Content="New joke"
								Command="{Binding NextJokeCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>
                </Grid>

            </StackPanel>

            <Border.Style>
                <Style TargetType="Border">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsJokeVisible}" Value="True">

                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="1"
															 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="1"
															 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="1"
															 Duration="0:0:0.25"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="0"
															 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="0.92"
															 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="0.92"
															 Duration="0:0:0.2"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>

                        </DataTrigger>

                    </Style.Triggers>

                </Style>
            </Border.Style>



        </Border>



        <Border Grid.Column="0"
        Width="320"
        Height="300"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="24"
        Margin="20"
        VerticalAlignment="Center"
        Style="{StaticResource AnimatedPanelStyle}"
        Visibility="{Binding IsFactVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
            </Border.Effect>

            <StackPanel>

                <TextBlock Text="Zanimivosti"
							   FontSize="36"
							   FontWeight="SemiBold"
							   Margin="0,0,0,20"/>

                <TextBlock Text="{Binding FactText}"
							   TextWrapping="Wrap"
							   FontSize="18"
							   Foreground="#514B56"
							   LineHeight="28"
							   Margin="0,0,0,28"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
								Content="Nazaj"
								Command="{Binding PreviousFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>

                    <Button Grid.Column="1"
								Content="Naprej"
								Command="{Binding NextFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>
                </Grid>

            </StackPanel>



        </Border>
        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,20">

            <StackPanel Margin="0,0,56,12"
							Opacity="0"
							RenderTransformOrigin="0.5,1"
							Visibility="{Binding AreBubblesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                <StackPanel.RenderTransform>
                    <ScaleTransform ScaleX="0.8"
										ScaleY="0.8"/>
                </StackPanel.RenderTransform>

                <StackPanel.Style>
                    <Style TargetType="StackPanel">

                        <Style.Triggers>

                            <DataTrigger Binding="{Binding AreBubblesVisible}" Value="True">

                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="1"
																 Duration="0:0:0.2"/>

                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="1"
																 Duration="0:0:0.2"/>

                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="1"
																 Duration="0:0:0.2"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>

                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="0"
																 Duration="0:0:0.15"/>

                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="0.8"
																 Duration="0:0:0.15"/>

                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="0.8"
																 Duration="0:0:0.15"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>

                            </DataTrigger>

                        </Style.Triggers>

                    </Style>
                </StackPanel.Style>

                <Border Style="{StaticResource HelperBubbleStyle}">
                    <Button Content="Beležka"
								Command="{Binding OpenNoteCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
                </Border>

                <Border Style="{StaticResource HelperBubbleStyle}">
                    <Button Content="Šale" Command="{Binding OpenJokeCommand}" Background="Transparent" BorderThickness="0" FontSize="16"/>
                </Border>
                <Border Style="{StaticResource HelperBubbleStyle}">
                    <Button Content="Zanimivosti"
								Command="{Binding OpenFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
                </Border>
                <Border Style="{StaticResource HelperBubbleStyle}" />
            </StackPanel>

            <Button Style="{StaticResource HelperCircleButtonStyle}"
						Command="{Binding ToggleBubblesCommand}" />
        </StackPanel>

    </Grid>

</Window>
