<Window x:Class="Trojan.Views.HelperOverlayWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
		xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"  
		xmlns:notepad="clr-namespace:Trojan.Views"
        
		Title="HelperOverlayWindow"
        Width="850"
		Height="620"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        Focusable="True"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

		<Window.Resources>
			<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		</Window.Resources>

		<Grid Background="Transparent">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="560"/>
				<ColumnDefinition Width="240"/>
			</Grid.ColumnDefinitions>


			<Image Grid.Column="1"
			   Width="80"
			   Height="80"
			   Margin="0,0,8,22"
			   HorizontalAlignment="Right"
			   VerticalAlignment="Bottom"
			   Stretch="Uniform"
			   Panel.ZIndex="999"
			   IsHitTestVisible="False"
			   gif:ImageBehavior.AnimatedSource="{Binding AvatarGif}"
			/>

			<!-- Notepad  -->
			<notepad:NotePadPanel Grid.Column="0" />

			<!-- Jokes -->
			<Border Grid.Column="0"
				Width="320"
				Height="300"
				Background="#F7F2F8"
				CornerRadius="18"
				Padding="24"
				Margin="20"
				VerticalAlignment="Center"
				Opacity="0"
				RenderTransformOrigin="0.5,0.5"
				Visibility="{Binding IsJokeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

				<Border.Effect>
					<DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
				</Border.Effect>

				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.9"
									ScaleY="0.9"/>
				</Border.RenderTransform>

				<StackPanel>

					<TextBlock Text="Šale"
							   FontSize="36"
							   FontWeight="SemiBold"
							   Margin="0,0,0,20"/>

					<TextBlock Text="{Binding JokeText}"
							   TextWrapping="Wrap"
							   FontSize="18"
							   Foreground="#514B56"
							   LineHeight="28"
							   Margin="0,0,0,28"/>

					<Grid>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
								Content="Nazaj"
								Command="{Binding PreviousJokeCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>

						<Button Grid.Column="1"
								Content="Naprej"
								Command="{Binding NextJokeCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8" RenderTransformOrigin="0.5,0.5">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="-4.789"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Button.RenderTransform>
                    </Button>
                </Grid>

				</StackPanel>

				<Border.Style>
					<Style TargetType="Border">

						<Style.Triggers>

							<DataTrigger Binding="{Binding IsJokeVisible}" Value="True">

								<DataTrigger.EnterActions>
									<BeginStoryboard>
										<Storyboard>

											<DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="1"
															 Duration="0:0:0.25"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="1"
															 Duration="0:0:0.25"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="1"
															 Duration="0:0:0.25"/>

										</Storyboard>
									</BeginStoryboard>
								</DataTrigger.EnterActions>

								<DataTrigger.ExitActions>
									<BeginStoryboard>
										<Storyboard>

											<DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="0"
															 Duration="0:0:0.2"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="0.92"
															 Duration="0:0:0.2"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="0.92"
															 Duration="0:0:0.2"/>

										</Storyboard>
									</BeginStoryboard>
								</DataTrigger.ExitActions>

							</DataTrigger>

						</Style.Triggers>

					</Style>
				</Border.Style>

				
				
			</Border>



			<Border Grid.Column="0"
				Width="320"
				Height="300"
				Background="#F7F2F8"
				CornerRadius="18"
				Padding="24"
				Margin="20"
				VerticalAlignment="Center"
				Style="{StaticResource AnimatedPanelStyle}"
				Visibility="{Binding IsFactVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

				<Border.Effect>
						<DropShadowEffect BlurRadius="18"
										  ShadowDepth="4"
										  Opacity="0.18"/>
					</Border.Effect>

					<StackPanel>

						<TextBlock Text="Zanimivosti"
								   FontSize="36"
								   FontWeight="SemiBold"
								   Margin="0,0,0,20"/>

						<TextBlock Text="{Binding FactText}"
								   TextWrapping="Wrap"
								   FontSize="18"
								   Foreground="#514B56"
								   LineHeight="28"
								   Margin="0,0,0,28"/>

						<Grid>

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<Button Grid.Column="0"
									Content="Nazaj"
									Command="{Binding PreviousFactCommand}"
									Background="Transparent"
									BorderThickness="0"
									FontSize="18"
									FontWeight="SemiBold"
									Foreground="#7A5AC8"/>

							<Button Grid.Column="1"
									Content="Naprej"
									Command="{Binding NextFactCommand}"
									Background="Transparent"
									BorderThickness="0"
									FontSize="18"
									FontWeight="SemiBold"
									Foreground="#7A5AC8"/>
						</Grid>

					</StackPanel>



			</Border>
			<StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,20">

				<StackPanel Margin="0,0,56,12"
							Opacity="0"
							RenderTransformOrigin="0.5,1"
							Visibility="{Binding AreBubblesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

					<StackPanel.RenderTransform>
						<ScaleTransform ScaleX="0.8"
										ScaleY="0.8"/>
					</StackPanel.RenderTransform>

					<StackPanel.Style>
						<Style TargetType="StackPanel">

							<Style.Triggers>

								<DataTrigger Binding="{Binding AreBubblesVisible}" Value="True">

									<DataTrigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>

												<DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="1"
																 Duration="0:0:0.2"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="1"
																 Duration="0:0:0.2"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="1"
																 Duration="0:0:0.2"/>

											</Storyboard>
										</BeginStoryboard>
									</DataTrigger.EnterActions>

									<DataTrigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>

												<DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="0"
																 Duration="0:0:0.15"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="0.8"
																 Duration="0:0:0.15"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="0.8"
																 Duration="0:0:0.15"/>

											</Storyboard>
										</BeginStoryboard>
									</DataTrigger.ExitActions>

								</DataTrigger>

							</Style.Triggers>

						</Style>
					</StackPanel.Style>
					
					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Beležka"
								Command="{Binding OpenNoteCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
					</Border>

					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Šale" Command="{Binding OpenJokeCommand}" Background="Transparent" BorderThickness="0" FontSize="16"/>
					</Border>
					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Zanimivosti"
								Command="{Binding OpenFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
					</Border>
					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Varnostno poročilo"
							Command="{Binding OpenSecurityReportCommand}"
							Background="Transparent"
							BorderThickness="0"
							FontSize="16"/>	
					</Border>
            </StackPanel>

				<Button Style="{StaticResource HelperCircleButtonStyle}"
						Command="{Binding ToggleBubblesCommand}" />
			</StackPanel>
        <Border Grid.Column="0"
        Width="360"
        Height="280"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="24"
        Margin="20"
        VerticalAlignment="Center"
        Style="{StaticResource AnimatedPanelStyle}"
        Visibility="{Binding IsSecurityReportVisible, 
                     Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.18"/>
            </Border.Effect>

            <StackPanel>

                <TextBlock Text="⚠ Zaznano na tvojem računalniku"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#A0522D"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

                <TextBlock Text="{Binding SecurityReportText}"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="#514B56"
                   LineHeight="22"
                   FontFamily="Consolas"
                   Margin="0,0,0,16"/>


            </StackPanel>

        </Border>
    </Grid>

	</Window>
