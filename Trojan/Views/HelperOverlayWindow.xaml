<Window x:Class="Trojan.Views.HelperOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
		xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"  
        
		Title="HelperOverlayWindow"
        Width="850"
		Height="620"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="True"
        Focusable="True"
        WindowStartupLocation="Manual"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

		<Window.Resources>
			<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		</Window.Resources>

		<Grid Background="Transparent">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="560"/>
				<ColumnDefinition Width="240"/>
			</Grid.ColumnDefinitions>


        <Image Grid.Column="1"
       Width="75"
       Height="70"
       Margin="0,0,13,24"
       HorizontalAlignment="Right"
       VerticalAlignment="Bottom"
       Stretch="Uniform"
       Panel.ZIndex="999"
       IsHitTestVisible="False"
       gif:ImageBehavior.AnimatedSource="{Binding AvatarGif}"/>

        <!-- NOTE -->
        <Border x:Name="NotePanel"
        Grid.Column="0"
        Width="500"
        Height="560"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="24"
        Margin="20"
        VerticalAlignment="Center"
        Opacity="0"
        RenderTransformOrigin="0.5,0.5"
        Visibility="{Binding IsNoteVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.18"/>
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.92"
                        ScaleY="0.92"/>
            </Border.RenderTransform>

            <Border.Style>
                <Style TargetType="Border">

                    <Style.Triggers>

                        <DataTrigger Binding="{Binding IsNoteVisible}" Value="True">

                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.25"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>

                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>

                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 To="0"
                                                 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                 To="0.92"
                                                 Duration="0:0:0.2"/>

                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                 To="0.92"
                                                 Duration="0:0:0.2"/>

                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>

                        </DataTrigger>

                    </Style.Triggers>

                </Style>
            </Border.Style>

            <Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="90"/>
						<RowDefinition Height="50"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="70"/>
						<RowDefinition Height="70"/>
						<RowDefinition Height="70"/>
					</Grid.RowDefinitions>

					<!-- HANDLE -->
					<Border Width="42"
							Height="6"
							CornerRadius="3"
							Background="#8F8791"
							HorizontalAlignment="Center"
							Margin="0,0,0,20"/>

					<!-- TITLE -->
					<Border Grid.Row="1"
							Background="#EAE4EC"
							CornerRadius="10"
							Padding="16">

						<StackPanel>

							<TextBlock Text="Naslov"
									   FontSize="14"
									   Foreground="#5C5661"/>

							<TextBox	Text="" FontSize="22"
									 Background="Transparent"
									 BorderThickness="0"/>
						</StackPanel>

					</Border>

					<!-- TOOLBAR -->
					<Grid Grid.Row="2"
						  Margin="8,12">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<StackPanel Orientation="Horizontal">

							<Button Content="B"
									FontWeight="Bold"
									Width="32"
									Height="32"
									Background="Transparent"
									BorderThickness="0"/>

							<Button Content="☰"
									Width="32"
									Height="32"
									Background="Transparent"
									BorderThickness="0"/>
						</StackPanel>

					</Grid>

					<!-- DESCRIPTION -->
					<Border Grid.Row="3"
							Background="#EAE4EC"
							CornerRadius="10"
							Padding="16">

						<StackPanel>

							<TextBlock Text="Opis"
									   FontSize="14"
									   Foreground="#5C5661"/>

							<TextBox Text=""
									 AcceptsReturn="True"
									 TextWrapping="Wrap"
									 VerticalScrollBarVisibility="Auto"
									 Background="Transparent"
									 BorderThickness="0"
									 FontSize="22"/>
						</StackPanel>

					</Border>

					<!-- DATES -->
					<Grid Grid.Row="4"
						  Margin="0,18,0,0">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="20"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Border Grid.Column="0"
								Background="#F7F2F8"
								BorderBrush="#D8D0DA"
								BorderThickness="1"
								CornerRadius="10"
								Padding="14">

							<TextBlock Text="Datum spremembe:"
									   FontWeight="SemiBold"/>
						</Border>

						<Border Grid.Column="2"
								Background="#F7F2F8"
								BorderBrush="#D8D0DA"
								BorderThickness="1"
								CornerRadius="10"
								Padding="14">

							<TextBlock Text="Datum kreiranja: "
									   FontWeight="SemiBold"/>
						</Border>

					</Grid>

					<Button Grid.Row="5"
							Content="Shrani beležko"
							Margin="0,20,0,0"
							FontSize="20"
							FontWeight="SemiBold"
							Background="#DCCFEB"
							Foreground="#4A4150"
							BorderThickness="0"
							Height="56"
							Cursor="Hand"/>


					<Button Grid.Row="6"
						Content="Ogled starih beležk"
						Margin="0,16,0,0"
						FontSize="20"
						FontWeight="SemiBold"
						Background="#DCCFEB"
						Foreground="#4A4150"
						BorderThickness="0"
						Height="56"
						Command="{Binding OpenHistoryCommand}"
						Cursor="Hand"/>

				</Grid>
	

	
				

			</Border>

			<Border Grid.Column="0"
        Width="500"
        Height="560"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="20"
        Margin="20"
        VerticalAlignment="Center"
        Visibility="{Binding IsHistoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

				<Border.Effect>
					<DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
				</Border.Effect>

				<StackPanel>

					<!-- HANDLE -->
					<Border Width="42"
							Height="6"
							CornerRadius="3"
							Background="#8F8791"
							HorizontalAlignment="Center"
							Margin="0,0,0,24"/>

					<!-- NOTE ITEM -->
					<Border Background="#FBF7FB"
							Padding="14"
							Margin="0,0,0,14">

						<Grid>

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="80"/>
							</Grid.ColumnDefinitions>

							<StackPanel>

								<TextBlock Text="Opomba zase: včasih je dovolj..."
										   FontSize="18"
										   FontWeight="SemiBold"/>

								<TextBlock Text="Danes sem imel čuden občutek, kot da se nekaj pomembnega skriva tik za robom dneva..."
										   TextWrapping="Wrap"
										   FontSize="14"
										   Margin="0,6,0,0"/>
							</StackPanel>

							<StackPanel Grid.Column="1"
										Orientation="Horizontal"
										HorizontalAlignment="Right">

								<Button Content="✎"
										Width="30"
										Height="30"
										Background="Transparent"
										BorderThickness="0"/>

								<Button Content="⊗"
										Width="30"
										Height="30"
										Background="Transparent"
										BorderThickness="0"/>
							</StackPanel>

						</Grid>

					</Border>

					<!-- duplicate items -->
					<Border Background="#FBF7FB"
							Height="90"
							Margin="0,0,0,14"/>

					<Border Background="#FBF7FB"
							Height="90"
							Margin="0,0,0,14"/>

					<Border Background="#FBF7FB"
							Height="90"
							Margin="0,0,0,20"/>

					<!-- ADD BUTTON -->
					<Button Content="Dodaj beležko"
							Height="56"
							Background="#DCCFEB"
							BorderThickness="0"
							FontSize="20"
							FontWeight="SemiBold"/>

				</StackPanel>


			</Border>


			<Border Grid.Column="0"
				Width="320"
				Height="300"
				Background="#F7F2F8"
				CornerRadius="18"
				Padding="24"
				Margin="20"
				VerticalAlignment="Center"
				Opacity="0"
				RenderTransformOrigin="0.5,0.5"
				Visibility="{Binding IsJokeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

				<Border.Effect>
					<DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
				</Border.Effect>

				<Border.RenderTransform>
					<ScaleTransform ScaleX="0.9"
									ScaleY="0.9"/>
				</Border.RenderTransform>

				<StackPanel>

					<TextBlock Text="Šale"
							   FontSize="36"
							   FontWeight="SemiBold"
							   Margin="0,0,0,20"/>

					<TextBlock Text="{Binding JokeText}"
							   TextWrapping="Wrap"
							   FontSize="18"
							   Foreground="#514B56"
							   LineHeight="28"
							   Margin="0,0,0,28"/>

					<Grid>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
								Content="Nazaj"
								Command="{Binding PreviousJokeCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>

						<Button Grid.Column="1"
								Content="Naprej"
								Command="{Binding NextJokeCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>
					</Grid>

				</StackPanel>

				<Border.Style>
					<Style TargetType="Border">

						<Style.Triggers>

							<DataTrigger Binding="{Binding IsJokeVisible}" Value="True">

								<DataTrigger.EnterActions>
									<BeginStoryboard>
										<Storyboard>

											<DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="1"
															 Duration="0:0:0.25"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="1"
															 Duration="0:0:0.25"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="1"
															 Duration="0:0:0.25"/>

										</Storyboard>
									</BeginStoryboard>
								</DataTrigger.EnterActions>

								<DataTrigger.ExitActions>
									<BeginStoryboard>
										<Storyboard>

											<DoubleAnimation Storyboard.TargetProperty="Opacity"
															 To="0"
															 Duration="0:0:0.2"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
															 To="0.92"
															 Duration="0:0:0.2"/>

											<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
															 To="0.92"
															 Duration="0:0:0.2"/>

										</Storyboard>
									</BeginStoryboard>
								</DataTrigger.ExitActions>

							</DataTrigger>

						</Style.Triggers>

					</Style>
				</Border.Style>

				
				
			</Border>



			<Border Grid.Column="0"
        Width="320"
        Height="300"
        Background="#F7F2F8"
        CornerRadius="18"
        Padding="24"
        Margin="20"
        VerticalAlignment="Center"
        Style="{StaticResource AnimatedPanelStyle}"
        Visibility="{Binding IsFactVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

				<Border.Effect>
					<DropShadowEffect BlurRadius="18"
									  ShadowDepth="4"
									  Opacity="0.18"/>
				</Border.Effect>

				<StackPanel>

					<TextBlock Text="Zanimivosti"
							   FontSize="36"
							   FontWeight="SemiBold"
							   Margin="0,0,0,20"/>

					<TextBlock Text="{Binding FactText}"
							   TextWrapping="Wrap"
							   FontSize="18"
							   Foreground="#514B56"
							   LineHeight="28"
							   Margin="0,0,0,28"/>

					<Grid>

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Button Grid.Column="0"
								Content="Nazaj"
								Command="{Binding PreviousFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>

						<Button Grid.Column="1"
								Content="Naprej"
								Command="{Binding NextFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="18"
								FontWeight="SemiBold"
								Foreground="#7A5AC8"/>
					</Grid>

				</StackPanel>



			</Border>
			<StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,20">

				<StackPanel Margin="0,0,56,12"
							Opacity="0"
							RenderTransformOrigin="0.5,1"
							Visibility="{Binding AreBubblesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

					<StackPanel.RenderTransform>
						<ScaleTransform ScaleX="0.8"
										ScaleY="0.8"/>
					</StackPanel.RenderTransform>

					<StackPanel.Style>
						<Style TargetType="StackPanel">

							<Style.Triggers>

								<DataTrigger Binding="{Binding AreBubblesVisible}" Value="True">

									<DataTrigger.EnterActions>
										<BeginStoryboard>
											<Storyboard>

												<DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="1"
																 Duration="0:0:0.2"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="1"
																 Duration="0:0:0.2"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="1"
																 Duration="0:0:0.2"/>

											</Storyboard>
										</BeginStoryboard>
									</DataTrigger.EnterActions>

									<DataTrigger.ExitActions>
										<BeginStoryboard>
											<Storyboard>

												<DoubleAnimation Storyboard.TargetProperty="Opacity"
																 To="0"
																 Duration="0:0:0.15"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
																 To="0.8"
																 Duration="0:0:0.15"/>

												<DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
																 To="0.8"
																 Duration="0:0:0.15"/>

											</Storyboard>
										</BeginStoryboard>
									</DataTrigger.ExitActions>

								</DataTrigger>

							</Style.Triggers>

						</Style>
					</StackPanel.Style>
					
					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Beležka"
								Command="{Binding OpenNoteCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
					</Border>

					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Šale" Command="{Binding OpenJokeCommand}" Background="Transparent" BorderThickness="0" FontSize="16"/>
					</Border>
					<Border Style="{StaticResource HelperBubbleStyle}">
						<Button Content="Zanimivosti"
								Command="{Binding OpenFactCommand}"
								Background="Transparent"
								BorderThickness="0"
								FontSize="16"/>
					</Border>
					<Border Style="{StaticResource HelperBubbleStyle}" />
				</StackPanel>

				<Button Style="{StaticResource HelperCircleButtonStyle}"
						Command="{Binding ToggleBubblesCommand}" />
			</StackPanel>

		</Grid>

	</Window>
