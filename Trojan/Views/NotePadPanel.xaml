<UserControl x:Class="Trojan.Views.NotePadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>

        <Border x:Name="NotePanel"
                Width="500"
                Height="560"
                Background="#F7F2F8"
                CornerRadius="18"
                Padding="24"
                Margin="20"
                VerticalAlignment="Center"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5"
                Visibility="{Binding IsNoteVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="4"
                              Opacity="0.18" />
        </Border.Effect>

        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.92"
                            ScaleY="0.92" />
        </Border.RenderTransform>

        <Border.Style>
            <Style TargetType="Border">

                <Style.Triggers>

                    <DataTrigger Binding="{Binding IsNoteVisible}" Value="True">

                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>

                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.25" />

                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                     To="1"
                                                     Duration="0:0:0.25" />

                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                     To="1"
                                                     Duration="0:0:0.25" />

                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>

                        <DataTrigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>

                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.2" />

                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                     To="0.92"
                                                     Duration="0:0:0.2" />

                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                     To="0.92"
                                                     Duration="0:0:0.2" />

                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.ExitActions>

                    </DataTrigger>

                </Style.Triggers>

            </Style>
        </Border.Style>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="90" />
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

          

            <!-- TITLE -->
            <Border Grid.Row="1"
                    Background="#EAE4EC"
                    CornerRadius="10"
                    Padding="16">

                <StackPanel>

                    <TextBlock Text="Naslov"
                               FontSize="14"
                               Foreground="#5C5661" />

                    <TextBox Text="{Binding Main.SelectedNote.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="22"
                             Background="Transparent"
                             BorderThickness="0" />
                </StackPanel>

            </Border>

            <!-- TOOLBAR -->
            <Grid Grid.Row="2"
                  Margin="8,12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <Button Content="B"
                            FontWeight="Bold"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BoldButton_Click" />

                    <Button Content="☰"
                            Width="32"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BulletListButton_Click" />
					
					<Button Content="I"
							FontStyle="Italic"
							Width="32"
			                Height="32"
							Background="Transparent"
                            BorderThickness="0"
			                Click="ItalicButton_Click"/>	
					
					<Button Content="T"
		                    FontStyle="Italic"
		                    Width="32"
		                    Height="32"
		                    Background="Transparent"
		                    BorderThickness="0"
                         Click="InsertTable_Click"/>

                    <ComboBox x:Name="TableSizeComboBox"
                              Width="86"
                              Height="32"
                              Margin="6,0,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              VerticalContentAlignment="Center"
                              SelectedIndex="0"
                              SelectionChanged="TableSizeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Tabela" IsEnabled="False" />
                        <ComboBoxItem Content="2x2" Tag="2x2" />
                        <ComboBoxItem Content="3x3" Tag="3x3" />
                        <ComboBoxItem Content="2x3" Tag="2x3" />
                        <ComboBoxItem Content="1x2" Tag="1x2" />
                        <ComboBoxItem Content="1x3" Tag="1x3" />
                    </ComboBox>

                 
                    <ComboBox x:Name="TextColorComboBox"
                              Width="110"
                              Height="32"
                              Margin="6,0,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              VerticalContentAlignment="Center"
                              SelectedIndex="0"
                              SelectionChanged="TextColorComboBox_SelectionChanged">
                        <ComboBoxItem Content="Barva" IsEnabled="False" />
                        <ComboBoxItem Tag="#000000">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="A" Foreground="#000000" FontWeight="SemiBold" />
                                <TextBlock Text="  Črna" Foreground="#4A4150" />
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#4A90E2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="A" Foreground="#4A90E2" FontWeight="SemiBold" />
                                <TextBlock Text="  Modra" Foreground="#4A4150" />
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#7ED321">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="A" Foreground="#7ED321" FontWeight="SemiBold" />
                                <TextBlock Text="  Zelena" Foreground="#4A4150" />
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#F5A623">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="A" Foreground="#F5A623" FontWeight="SemiBold" />
                                <TextBlock Text="  Oranžna" Foreground="#4A4150" />
                            </StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#D0021B">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="A" Foreground="#D0021B" FontWeight="SemiBold" />
                                <TextBlock Text="  Rdeča" Foreground="#4A4150" />
                            </StackPanel>
                        </ComboBoxItem>
                    </ComboBox>
                </StackPanel>

            </Grid>

            <!-- DESCRIPTION -->
			<Border Grid.Row="3"
                    Background="#EAE4EC"
                    CornerRadius="10"
                    Padding="16">

				<Grid>

					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<TextBlock Text="Opis"
							   FontSize="14"
							   Foreground="#5C5661"/>

					<RichTextBox Grid.Row="1"
								 x:Name="NoteContentRichTextBox"
								 VerticalScrollBarVisibility="Auto"
								 HorizontalScrollBarVisibility="Auto"
								 Background="Transparent"
								 BorderThickness="0"
								 FontSize="18"/>
				</Grid>
			</Border>

			<Grid Grid.Row="4">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<!-- SHRANI -->
				<Border Grid.Column="0"
						CornerRadius="14"
						Background="#DCCFEB"
						Margin="0,16,6,0">

					<Button Content="Shrani beležko"
							Height="56"
							FontSize="20"
							FontWeight="SemiBold"
							Background="Transparent"
							Foreground="#4A4150"
							BorderThickness="0"
							Cursor="Hand"
							Command="{Binding SaveNoteCommand}" />
				</Border>

				<!-- ZGODOVINA -->
				<Border Grid.Column="1"
						CornerRadius="14"
						Background="#DCCFEB"
						Margin="6,16,0,0">

					<Button Content="Ogled starih beležk"
							Height="56"
							FontSize="20"
							FontWeight="SemiBold"
							Background="Transparent"
							Foreground="#4A4150"
							BorderThickness="0"
							Cursor="Hand"
							Command="{Binding OpenHistoryCommand}" />
				</Border>
			</Grid>
        </Grid>

        </Border>

        <Border x:Name="HistoryPanel"
                Width="500"
                Height="560"
                Background="#F7F2F8"
                CornerRadius="18"
                Padding="20"
                Margin="20"
                VerticalAlignment="Center"
                Visibility="{Binding IsHistoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.18" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- HANDLE -->
                <Border Width="42"
                        Height="6"
                        CornerRadius="3"
                        Background="#8F8791"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24" />

                <TextBlock Grid.Row="0"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#4A4150"
                           Text="Vse bele&#382;ke" />

                <ListBox Grid.Row="1"
                         Margin="0,0,0,12"
                         Background="#FBF7FB"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ItemsSource="{Binding Main.Notes}"
                         SelectedItem="{Binding Main.SelectedNote, Mode=TwoWay}"
                         MouseDoubleClick="NotesHistoryListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="#E3DAE8"
                                    Background="#FFFFFF">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title, TargetNullValue=(brez naslova)}"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CreatedAt, StringFormat=Kreirano: {0:dd.MM.yyyy HH:mm}}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="#5C5661" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Odpri"
                                            Padding="12,6"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.OpenNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- ADD BUTTON -->
				<Grid Grid.Row="2">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<!-- DODAJ BELEŽKO -->
					<Border Grid.Column="0"
							CornerRadius="14"
							Background="#DCCFEB"
							Margin="0,0,6,0">

						<Button Content="Dodaj beležko"
								Height="52"
								FontSize="18"
								FontWeight="SemiBold"
								Background="Transparent"
								BorderThickness="0"
								Cursor="Hand"
								Command="{Binding CreateNoteCommand}" />
					</Border>

					<!-- IZBRIŠI -->
					<Border Grid.Column="1"
							CornerRadius="14"
							Background="#E8DDE8"
							Margin="6,0,0,0">

						<Button Content="Izbriši izbrano"
								Height="52"
								FontSize="18"
								FontWeight="SemiBold"
								Background="Transparent"
								BorderThickness="0"
								Cursor="Hand"
								Command="{Binding DeleteNoteCommand}" />
					</Border>
				</Grid>
            </Grid>

        </Border>

    </Grid>

</UserControl>
