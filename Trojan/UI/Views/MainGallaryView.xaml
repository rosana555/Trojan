<UserControl x:Class="Trojan.UI.Views.MainGallaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Trojan.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>

        <Border x:Name="GallaryWindow"
                MaxWidth="800"
                MaxHeight="500"
                Background="White"
                CornerRadius="18"
                Padding="24"
                Margin="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding IsGallaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.18"/>
            </Border.Effect>

            <Grid>

                <!-- ROWS -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TITLE -->
                <TextBlock x:Name="GalleryTitle"
                           Grid.Row="0"
                           Text="Albums"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <!-- CONTENT -->
                <Border Grid.Row="1"
                        Style="{StaticResource GalleryContentStyle}"
                        Margin="0,0,0,16">

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

                        <WrapPanel x:Name="GalleryPanel"
                                   Orientation="Horizontal"
                                   ItemWidth="230"
                                   ItemHeight="260"/>

                    </ScrollViewer>

                </Border>

                <!-- BUTTONS -->
                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ADD BUTTON -->
                    <Border Grid.Column="0"
                            Style="{StaticResource GalleryButtonStyle}"
                            Margin="0,0,6,0">

                        <Button Content="Dodaj sliko"
                                Height="50"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"/>

                    </Border>

                    <!-- BACK BUTTON -->
                    <Border Grid.Column="1"
                            Style="{StaticResource GalleryButtonStyle}"
                            Margin="6,0,0,0">

                        <Button Content="Nazaj"
                                Height="50"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BackButton_Click"/>

                    </Border>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</UserControl>