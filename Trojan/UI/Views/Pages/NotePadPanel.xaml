<UserControl x:Class="Trojan.UI.Views.Pages.NotePadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="500">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>

        <!-- ================= NOTE PANEL ================= -->
        <Border x:Name="NotePanel"
                Width="500"
                Height="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F7F2F8"
                CornerRadius="18"
                Padding="24"
                Margin="20"
                Opacity="1"
                RenderTransformOrigin="0.5,0.5"
                Visibility="{Binding IsNoteVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.18" />
            </Border.Effect>

            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.92"
                                ScaleY="0.92" />
            </Border.RenderTransform>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="90" />
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="70" />
                </Grid.RowDefinitions>

                <!-- TITLE -->
                <Border Grid.Row="1"
                        Background="#EAE4EC"
                        CornerRadius="10"
                        Padding="16">

                    <StackPanel>
                        <TextBlock Text="Naslov"
                                   FontSize="14"
                                   Foreground="#5C5661" />

                        <TextBox Text="{Binding Main.SelectedNote.Title,
                                        Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="200"
                                 FontSize="22"
                                 Background="Transparent"
                                 BorderThickness="0" />
                    </StackPanel>
                </Border>

                <!-- TOOLBAR -->
                <Grid Grid.Row="2" Margin="8,12">

                    <StackPanel Orientation="Horizontal">

                        <Button Content="B" Width="32" Height="32"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BoldButton_Click"/>

                        <Button Content="I" Width="32" Height="32"
                                FontStyle="Italic"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="ItalicButton_Click"/>

                        <Button Content="☰" Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BulletListButton_Click"/>

                        <Button Content="1." Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="NumberedListButton_Click"/>

                        <Button Content="_" Width="32" Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="UnderlineButton_Clic1k"/>

                        <!-- TABLE -->
                        <ComboBox x:Name="TableSizeComboBox"
                                  Width="86"
                                  Height="32"
                                  Margin="6,0,0,0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0"
                                  SelectionChanged="TableSizeComboBox_SelectionChanged">

                            <ComboBoxItem Content="Tabela" IsEnabled="False" />
                            <ComboBoxItem Content="2x2" Tag="2x2" />
                            <ComboBoxItem Content="3x3" Tag="3x3" />
                            <ComboBoxItem Content="2x3" Tag="2x3" />
                            <ComboBoxItem Content="1x2" Tag="1x2" />
                            <ComboBoxItem Content="1x3" Tag="1x3" />
                        </ComboBox>

                        <!-- COLORS -->
                        <ComboBox x:Name="TextColorComboBox"
                                  Width="110"
                                  Height="32"
                                  Margin="6,0,0,0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalContentAlignment="Center"
                                  SelectedIndex="0"
                                  SelectionChanged="TextColorComboBox_SelectionChanged">

                            <ComboBoxItem Content="Barva" IsEnabled="False" />

                            <ComboBoxItem Tag="#000000">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A" Foreground="#000000" FontWeight="SemiBold"/>
                                    <TextBlock Text=" Črna"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="#4A90E2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A" Foreground="#4A90E2" FontWeight="SemiBold"/>
                                    <TextBlock Text=" Modra"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="#7ED321">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A" Foreground="#7ED321" FontWeight="SemiBold"/>
                                    <TextBlock Text=" Zelena"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="#F5A623">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A" Foreground="#F5A623" FontWeight="SemiBold"/>
                                    <TextBlock Text=" Oranžna"/>
                                </StackPanel>
                            </ComboBoxItem>

                            <ComboBoxItem Tag="#D0021B">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="A" Foreground="#D0021B" FontWeight="SemiBold"/>
                                    <TextBlock Text=" Rdeča"/>
                                </StackPanel>
                            </ComboBoxItem>

                        </ComboBox>

                    </StackPanel>
                </Grid>

                <!-- DESCRIPTION -->
                <Border Grid.Row="3"
                        Background="#EAE4EC"
                        CornerRadius="10"
                        Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Opis"
                                   FontSize="14"
                                   Foreground="#5C5661"/>

                        <RichTextBox Grid.Row="1"
                                      x:Name="NoteContentRichTextBox"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Background="Transparent"
                                      TextChanged="NoteContentRichTextBox_TextChanged"
                                      BorderThickness="0"
                                      FontSize="18"/>
                    </Grid>
                </Border>

                <!-- SAVE + HISTORY -->
                <Grid Grid.Row="4">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="14"
                            Background="#DCCFEB"
                            Margin="0,16,6,0">

                        <Button Content="Shrani beležko"
                                Height="56"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding SaveNoteCommand}" />
                    </Border>

                    <Border Grid.Column="1"
                            CornerRadius="14"
                            Background="#DCCFEB"
                            Margin="6,16,0,0">

                        <Button Content="Ogled starih beležk"
                                Height="56"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding OpenHistoryCommand}" />
                    </Border>

                </Grid>

            </Grid>
        </Border>

        <!-- ================= HISTORY PANEL ================= -->
        <Border x:Name="HistoryPanel"
                Width="500"
                Height="560"
                Background="#F7F2F8"
                CornerRadius="18"
                Padding="20"
                Margin="20"
                VerticalAlignment="Center"
                Visibility="{Binding IsHistoryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.18" />
            </Border.Effect>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock HorizontalAlignment="Center"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#4A4150"
                               Text="Vse beležke" />

                    <Border Grid.Column="1"
                            CornerRadius="10"
                            Background="#DCCFEB"
                            Visibility="{Binding Main.CanUndoDelete,
                                         Converter={StaticResource BooleanToVisibilityConverter}}">


                        <Button Padding="12,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding UndoDeleteCommand}">

                            <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE7A7;"
                                   FontSize="16"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                    </Border>

                </Grid>

                <!-- LIST -->
                <ListBox Grid.Row="1"
                         Margin="0,0,0,12"
                         Background="#FBF7FB"
                         BorderThickness="0"
                         ItemsSource="{Binding Main.Notes}"
                         SelectedItem="{Binding Main.SelectedNote, Mode=TwoWay}"
                         HorizontalContentAlignment="Stretch">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Border Padding="14"
                                    Margin="0,0,0,10"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="#E3DAE8"
                                    Background="#FFFFFF">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- LEFT -->
                                    <StackPanel Grid.Column="0">

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title, TargetNullValue=(brez naslova)}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>


                                            <Border Margin="8,0,0,0"
                                                Padding="6,2"
                                                CornerRadius="6"
                                                Background="#DCCFEB"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsPinned,
                                                Converter={StaticResource BooleanToVisibilityConverter}}">

                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE718;"
                                                   FontSize="12"
                                                   Foreground="#4A4150"
                                                   VerticalAlignment="Center"/>
                                            </Border>

                                        </StackPanel>

                                        <TextBlock Text="{Binding CreatedAt, StringFormat=Kreirano: {0:dd.MM.yyyy HH:mm}}"
                                                   FontSize="12"
                                                   Foreground="#5C5661"/>

                                        <TextBlock Text="{Binding EditedAt, StringFormat=Urejeno: {0:dd.MM.yyyy HH:mm}}"
                                                   FontSize="12"
                                                   Foreground="#5C5661"/>

                                    </StackPanel>

                                    <!-- RIGHT ACTIONS (CONSISTENT STYLE) -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">

                                        <!-- ODPRE -->
                                        <Border CornerRadius="10"
                                                Background="#DCCFEB"
                                                Margin="0,0,8,0">

                                            <Button Padding="12,6"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.OpenNoteForNoteCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">

                                                                                        
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE70F;"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                                                                    </Button>
                                        </Border>

                                        <!-- PIN / UNPIN -->
                                        <Border CornerRadius="10"
                                                Background="#E8DDE8">

                                            <Button Padding="12,6"
                                                FontSize="14"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding DataContext.TogglePinForNoteCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">

                                                                                    
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                        FontSize="16"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">  

                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE718;" />
                                                            <!-- pin -->
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE77A;" />
                                                                    <!-- unpin -->
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>

                                                </TextBlock>
                                            </Button>

                                        </Border>

                                    </StackPanel>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

                <!-- FOOTER -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border CornerRadius="14"
                            Background="#DCCFEB"
                            Margin="0,0,6,0">

                        <Button Content="Dodaj beležko"
                                Height="52"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding CreateNoteCommand}" />
                    </Border>

                    <Border Grid.Column="1"
                            CornerRadius="14"
                            Background="#E8DDE8"
                            Margin="6,0,0,0">

                        <Button Content="Izbriši izbrano"
                                Height="52"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DeleteNoteCommand}" />
                    </Border>

                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>