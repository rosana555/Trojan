<UserControl x:Class="Trojan.UI.Views.Pages.MainGallaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Trojan.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- MAIN GALLERY -->
        <Border x:Name="GallaryWindow"
                MaxWidth="800"
                MaxHeight="500"
                Background="White"
                CornerRadius="18"
                Padding="24"
                Margin="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="{Binding DataContext.IsGallaryVisible,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="4"
                                  Opacity="0.18"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- TITLE -->
                    <TextBlock x:Name="GalleryTitle"
                               Grid.Column="0"
                               Text="Albums"
                               FontSize="24"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <!-- INPUT -->
                    <TextBox Grid.Column="1"
                             Margin="20,0,12,0"
                             Height="40"
                             VerticalAlignment="Center"
                             FontSize="16"
                             Padding="12,4"
                             Text="{Binding NewAlbumTitle}"
                             Visibility="{Binding IsCreatingAlbum,
                             Converter={StaticResource BooleanToVisibilityConverter}}"
                             ToolTip="Vpiši ime albuma"/>

                    <!-- SELECT THUMBNAIL -->
                    <Border Grid.Column="2"
                            Background="#F5F5F5"
                            CornerRadius="12"
                            Padding="8"
                            Visibility="{Binding IsCreatingAlbum,
                            Converter={StaticResource BooleanToVisibilityConverter}}">

                        <Button Content="Select thumbnail"
                                Padding="14,6"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SelectThumbnailButton_Click"/>

                    </Border>

                </Grid>

                <!-- CONTENT -->
                <Border Grid.Row="1"
                        Style="{StaticResource GalleryContentStyle}"
                        Margin="0,0,0,16">

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="4"
                                  ClipToBounds="False">

                        <WrapPanel x:Name="GalleryPanel"
                                   Orientation="Horizontal"
                                   ItemWidth="230"/>

                    </ScrollViewer>

                </Border>

                <!-- BUTTONS -->
                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- MAIN BUTTON -->
                    <Border Grid.Column="0"
                            Style="{StaticResource GalleryButtonStyle}"
                            Margin="0,0,6,0">

                        <Button Height="50"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="MainActionButton_Click">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Content"
                                            Value="Ustvari album"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding IsInsideAlbum}"
                                                     Value="True">

                                            <Setter Property="Content"
                                                    Value="Dodaj sliko"/>

                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsCreatingAlbum}"
                                                     Value="True">

                                            <Setter Property="Content"
                                                    Value="Shrani"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>
                            </Button.Style>

                        </Button>

                    </Border>

                    <!-- BACK -->
                    <Border Grid.Column="1"
                            Style="{StaticResource GalleryButtonStyle}"
                            Margin="6,0,0,0">

                        <Button Content="Nazaj"
                                Height="50"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="BackButton_Click"/>

                    </Border>

                </Grid>

            </Grid>

        </Border>

        <!-- ADD IMAGE OVERLAY -->
        <Grid Background="#66000000"
              Visibility="{Binding IsAddingImage,
              Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border Width="440"
                    Height="620"
                    Background="White"
                    CornerRadius="26"
                    Padding="26"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="22"
                                      ShadowDepth="4"
                                      Opacity="0.22"/>
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->
                    <Grid Grid.Row="0"
                          Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Dodaj sliko"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="#2D2D2D"
                                   VerticalAlignment="Center"/>

                        <!-- UPLOAD BUTTON -->
                        <Border Grid.Column="1"
                                Style="{StaticResource GalleryButtonStyle}">

                            <Button Content="Upload image"
                                    Height="44"
                                    Padding="18,0"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>

                        </Border>

                    </Grid>

                    <!-- IMAGE PREVIEW -->
                    <Border Grid.Row="1"
                            Height="220"
                            CornerRadius="20"
                            ClipToBounds="True"
                            Background="#F4F4F4"
                            BorderBrush="#ECECEC"
                            BorderThickness="1">

                        <!-- HARDCODED IMAGE -->
                        <Image Stretch="UniformToFill"
                               Source="/Trojan;component/UI/Assets/TestImages/image2.jpg"/>

                    </Border>

                    <!-- DESCRIPTION -->
                    <Border Grid.Row="2"
                            Margin="0,22,0,0"
                            CornerRadius="20"
                            Background="#FAFAFA"
                            BorderBrush="#ECECEC"
                            BorderThickness="1"
                            Padding="16">

                        <TextBox AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="15"
                                 Foreground="#444"
                                 Text="Type description..."
                                 CaretBrush="#444"/>

                    </Border>

                    <!-- BUTTONS -->

                    <Grid Grid.Row="3"
                          Margin="0,24,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- SAVE -->
                        <Border Grid.Column="0"
                                Style="{StaticResource GalleryButtonStyle}"
                                Margin="0">

                            <Button Content="Shrani"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"/>

                        </Border>

                        <!-- BACK -->
                        <Border Grid.Column="2"
                                Style="{StaticResource GalleryButtonStyle}"
                                Margin="0">
                            <Button Content="Nazaj"
                                    Height="50"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="CloseAddImageForm_Click"/>

                        </Border>

                    </Grid>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</UserControl>